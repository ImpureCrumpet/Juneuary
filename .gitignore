# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.python-version
*.egg-info/

# uv
uv.lock

# SQLite (regenerated from YAML)
db/*.db
db/*.db-journal
db/*.db-wal
db/*.db-shm

# Node (for future JS frontend)
node_modules/
dist/
build/
.pnpm-store/

# Editor / OS
.DS_Store
.vscode/
.idea/

# Generated reports (local output only; keep the folder)
reports/*
!reports/.gitkeep

# Local-only city / neighborhood configs. Neighborhood-specific entries
# (grid cells, ZIPs, blocks) are PII-adjacent and stay on disk only.
# See data/cities.local.example.yaml for the schema.
data/cities.local.yaml
data/cities/*.local.yaml

# Skills harness — native IDE discovery symlinks (machine-local)
.agents/skills/
.claude/skills/

# Cursor
.cursorrules
